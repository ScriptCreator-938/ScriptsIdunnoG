-- [[ ESP DROPPED TOOLS LOGIC ]]
local toolEspFolder = Instance.new("Folder", game.CoreGui)
toolEspFolder.Name = "ToolESP_Storage"

local function createToolEsp(toolModel)
    if not toolModel:IsA("Model") then return end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ToolESP"
    billboard.AlwaysOnTop = true
    billboard.Size = UDim2.new(0, 100, 0, 20)
    billboard.Adornee = toolModel:FindFirstChildWhichIsA("BasePart") or toolModel.PrimaryPart
    billboard.MaxDistance = 500
    billboard.Parent = toolEspFolder

    local label = Instance.new("TextLabel", billboard)
    label.BackgroundTransparency = 1
    label.Size = UDim2.new(1, 0, 1, 0)
    label.Text = toolModel.Name
    label.TextColor3 = Color3.fromRGB(255, 255, 0) 
    label.TextStrokeTransparency = 0
    label.Font = Enum.Font.GothamBold
    label.TextSize = 12

    toolModel.AncestryChanged:Connect(function()
        if not toolModel:IsDescendantOf(workspace) then
            billboard:Destroy()
        end
    end)
end

local function refreshToolEsp()
    toolEspFolder:ClearAllChildren()
    if espToolsEnabled then
        local droppedTools = workspace:FindFirstChild("DroppedTools")
        if droppedTools then
            for _, tool in ipairs(droppedTools:GetChildren()) do
                createToolEsp(tool)
            end
        end
    end
end

workspace:WaitForChild("DroppedTools").ChildAdded:Connect(function(child)
    if espToolsEnabled then
        task.wait(0.1)
        createToolEsp(child)
    end
end)

-- [[ AIMBOT LOGIC ]]
local function lookAt(targetPos)
    Cam.CFrame = CFrame.new(Cam.CFrame.Position, targetPos)
end

local criminalColors = {
    ["Slime green"] = true, ["Neon orange"] = true, ["Dusty Rose"] = true,
    ["Plum"] = true, ["Dark stone grey"] = true
}
local deepBlueGroup = {
    ["Deep blue"] = true, ["Black"] = true, ["Navy blue"] = true, ["Fossil"] = true
}

local function isEnemy(player)
    if not player.TeamColor or not LocalPlayer.TeamColor then return true end
    local myColor = LocalPlayer.TeamColor.Name
    local theirColor = player.TeamColor.Name
    if deepBlueGroup[myColor] then return not deepBlueGroup[theirColor] end
    if criminalColors[myColor] then return not criminalColors[theirColor] end
    return player.TeamColor ~= LocalPlayer.TeamColor
end

local function isDangerous(player)
    local char = player.Character
    if not char then return false end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool and table.find(dangerousItems, tool.Name) then return true end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do
            if table.find(dangerousItems, item.Name) then return true end
        end
    end
    return false
end

local function isNotInnocent(player)
    local svVars = player:FindFirstChild("ServerVariables")
    if svVars then
        local innocentVal = svVars:FindFirstChild("Innocent")
        if innocentVal and innocentVal:IsA("ValueBase") then
            return innocentVal.Value == false
        end
    end
    return true
end

-- KIỂM TRA STUNNED/TASED (RuleSC)
local function isStunnedOrTased(player)
    local svVars = player:FindFirstChild("ServerVariables")
    if svVars then
        local stunned = svVars:FindFirstChild("Stunned")
        local tased = svVars:FindFirstChild("Tased")
        if (stunned and stunned.Value == true) or (tased and tased.Value == true) then
            return true
        end
    end
    return false
end

-- KIỂM TRA CUFFED/DETAINED (MỚI - RuleSC)
local function isCuffedOrDetained(player)
    local svVars = player:FindFirstChild("ServerVariables")
    if svVars then
        local handcuffs = svVars:FindFirstChild("Handcuffs")
        if handcuffs then
            local cuffed = handcuffs:FindFirstChild("Cuffed")
            local detained = handcuffs:FindFirstChild("Detained")
            local is_c = (filterCuffed and cuffed and cuffed.Value == true)
            local is_d = (filterDetained and detained and detained.Value == true)
            return is_c or is_d
        end
    end
    return false
end

local function getClosestEnemyInFOV()
    local closest, closestDist = nil, math.huge
    local screenCenter = Cam.ViewportSize / 2

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if not isEnemy(player) then continue end
            if filterDangerous and not isDangerous(player) then continue end
            if filterInnocent and not isNotInnocent(player) then continue end
            if filterStunTase and isStunnedOrTased(player) then continue end
            if isCuffedOrDetained(player) then continue end -- Check mới

            local char = player.Character
            if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then continue end

            local head = char:FindFirstChild("Head")
            if head then
                local pos, onScreen = Cam:WorldToViewportPoint(head.Position)
                local dist = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude

                if onScreen and dist < fov and dist < closestDist then
                    local params = RaycastParams.new()
                    params.FilterType = Enum.RaycastFilterType.Blacklist
                    params.FilterDescendantsInstances = {LocalPlayer.Character, char}
                    local res = workspace:Raycast(Cam.CFrame.Position, head.Position - Cam.CFrame.Position, params)

                    if not res or res.Instance:IsDescendantOf(char) then
                        closestDist = dist
                        closest = player
                    end
                end
            end
        end
    end
    return closest
end

