-- [[ LOGIC FUNCTIONS ]]
local function isDangerous(player)
    local char = player.Character
    if not char then return false end
    local tool = char:FindFirstChildOfClass("Tool")
    if tool and table.find(dangerousItems, tool.Name) then return true end
    local bp = player:FindFirstChild("Backpack")
    if bp then
        for _, item in ipairs(bp:GetChildren()) do if table.find(dangerousItems, item.Name) then return true end end
    end
    return false
end

local function isNotInnocent(player)
    local svVars = player:FindFirstChild("ServerVariables")
    if svVars then
        local innocentVal = svVars:FindFirstChild("Innocent")
        if innocentVal and innocentVal:IsA("ValueBase") then return innocentVal.Value == false end
    end
    return true
end

local function checkTotalInnocence(player)
    if isDangerous(player) or isNotInnocent(player) then return false end
    return true 
end

local function isStunnedOrTased(player)
    local svVars = player:FindFirstChild("ServerVariables")
    if svVars then
        local stunned = svVars:FindFirstChild("Stunned")
        local tased = svVars:FindFirstChild("Tased")
        return (stunned and stunned.Value == true) or (tased and tased.Value == true)
    end
    return false
end

local function isCuffedOrDetained(player)
    local svVars = player:FindFirstChild("ServerVariables")
    if svVars then
        local handcuffs = svVars:FindFirstChild("Handcuffs")
        if handcuffs then
            local cuffed = handcuffs:FindFirstChild("Cuffed")
            local detained = handcuffs:FindFirstChild("Detained")
            return (filterCuffed and cuffed and cuffed.Value == true) or (filterDetained and detained and detained.Value == true)
        end
    end
    return false
end

local function isEnemy(player)
    local criminalColors = { ["Slime green"] = true, ["Neon orange"] = true, ["Dusty Rose"] = true, ["Plum"] = true, ["Dark stone grey"] = true }
    local deepBlueGroup = { ["Deep blue"] = true, ["Black"] = true, ["Navy blue"] = true, ["Fossil"] = true }
    if not player.TeamColor or not LocalPlayer.TeamColor then return true end
    local myColor = LocalPlayer.TeamColor.Name
    local theirColor = player.TeamColor.Name
    if deepBlueGroup[myColor] then return not deepBlueGroup[theirColor] end
    if criminalColors[myColor] then return not criminalColors[theirColor] end
    return player.TeamColor ~= LocalPlayer.TeamColor
end

-- [[ INNOCENT ESP LOGIC (TextSize = 11) ]]
local function createInnocentEsp(player)
    if innocentEspFolder:FindFirstChild(player.Name) then return end
    if not player.Character or not player.Character:FindFirstChild("Head") then return end
    
    local guiEsp = Instance.new("BillboardGui")
    guiEsp.Name = player.Name; guiEsp.Size = UDim2.new(0, 260, 0, 40); guiEsp.AlwaysOnTop = true; guiEsp.StudsOffset = Vector3.new(0, 3, 0); guiEsp.MaxDistance = 1000; guiEsp.Adornee = player.Character.Head; guiEsp.Parent = innocentEspFolder
    
    local txt = Instance.new("TextLabel", guiEsp)
    txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency = 1; txt.TextStrokeTransparency = 0; txt.Font = Enum.Font.GothamBold; 
    txt.TextSize = 11 -- CHỈNH NHỎ LẠI THEO YÊU CẦU
    
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not guiEsp.Parent or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            conn:Disconnect(); guiEsp:Destroy(); return
        end
        local dist = math.floor((LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude)
        local isActuallyInnocent = checkTotalInnocence(player)
        local status = isActuallyInnocent and "Innocent" or "Dangerous"
        txt.TextColor3 = isActuallyInnocent and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0)
        txt.Text = "Security: Max | Status: "..status.." | "..player.DisplayName.." (@"..player.Name..") | Studs: "..dist
    end)
end

-- [[ AIMBOT TARGET ]]
local function getClosestEnemyInFOV()
    local closest, closestDist = nil, math.huge
    local screenCenter = Cam.ViewportSize / 2
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if not isEnemy(player) or (filterDangerous and not isDangerous(player)) or (filterInnocent and not isNotInnocent(player)) or (filterStunTase and isStunnedOrTased(player)) or isCuffedOrDetained(player) then continue end
            local char = player.Character
            if not char or not char:FindFirstChild("Humanoid") or char.Humanoid.Health <= 0 then continue end
            local head = char:FindFirstChild("Head")
            if head then
                local pos, onScreen = Cam:WorldToViewportPoint(head.Position)
                local dist = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
                if onScreen and dist < fov and dist < closestDist then
                    closestDist = dist closest = player 
                end
            end
        end
    end
    return closest
end

