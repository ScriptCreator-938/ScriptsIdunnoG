-- [[ RENDER LOOP - GIỮ NGUYÊN 0.5 ]]
RunService:BindToRenderStep("AimbotUpdate", Enum.RenderPriority.Camera.Value + 1, function()
    updateDrawings()
    if not aimingEnabled or not LocalPlayer.Character then return end
    local head = LocalPlayer.Character:FindFirstChild("Head")
    if not head then return end
    local isFP = (Cam.CFrame.Position - head.Position).Magnitude <= 1
    fpLabel.Text = isFP and "First Person: ON" or "First Person: OFF"
    if not isFP then return end
    local target = getClosestEnemyInFOV()
    if target and target.Character then
        local tHead = target.Character:FindFirstChild("Head")
        local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
        if tHead and tHrp then
            local aimPosition = tHead.Position
            if predictionEnabled and predStrength > 0 then
                local velocity = tHrp.Velocity
                if velocity.Magnitude > 1 then
                    aimPosition = aimPosition + (velocity.Unit * (predStrength * 0.5))
                end
            end
            lookAt(aimPosition)
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.Delete then
        RunService:UnbindFromRenderStep("AimbotUpdate")
        FOVring:Remove()
        gui:Destroy()
        toolEspFolder:Destroy()
    end
end)
