-- === 4. LOGIC XỬ LÝ TOOL ===
local function ToggleTool(toolName)
    local char = Player.Character or Player.CharacterAdded:Wait()
    local bp = Player:WaitForChild("Backpack")
    local target = char:FindFirstChild(toolName) or bp:FindFirstChild(toolName)
    
    if target then
        if target.Parent == char then
            target.Parent = bp
        else
            -- Tự động cất tool cũ đang cầm trước khi lấy mới
            for _, item in pairs(char:GetChildren()) do
                if item:IsA("Tool") then item.Parent = bp end
            end
            target.Parent = char
        end
    end
end

local function AddButton(tName, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 180, 0, 35)
    btn.BackgroundColor3 = color
    btn.Text = tName
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.Parent = ToolFrame
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(function() ToggleTool(tName) end)
end

local function RefreshButtons()
    for _, child in pairs(ToolFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    local cat = Categories[currentCatIndex]
    MinBtn.Text = (cat == "ADVANCED") and "ADVANCED BP" or cat
    
    if cat == "ADVANCED" then
        local bp = Player:FindFirstChild("Backpack")
        local char = Player.Character
        local foundTools = {}

        if bp then
            for _, t in pairs(bp:GetChildren()) do
                if t:IsA("Tool") and not table.find(foundTools, t.Name) then
                    table.insert(foundTools, t.Name)
                    AddButton(t.Name, Color3.fromRGB(0, 150, 100))
                end
            end
        end
        if char then
            for _, t in pairs(char:GetChildren()) do
                if t:IsA("Tool") and not table.find(foundTools, t.Name) then
                    table.insert(foundTools, t.Name)
                    AddButton(t.Name, Color3.fromRGB(0, 150, 100))
                end
            end
        end
    else
        local color = (cat == "DOC" and Color3.fromRGB(0, 85, 255)) or (cat == "Prisoners" and Color3.fromRGB(150, 0, 0)) or Color3.fromRGB(90, 90, 90)
        for _, tName in pairs(ToolData[cat]) do
            AddButton(tName, color)
        end
    end
end

-- === 5. UPDATE LIÊN TỤC CHO ADVANCED MODE ===
local lastCount = -1
RunService.Heartbeat:Connect(function()
    if Categories[currentCatIndex] == "ADVANCED" then
        local bp = Player:FindFirstChild("Backpack")
        local char = Player.Character
        local currentCount = (bp and #bp:GetChildren() or 0) + (char and (char:FindFirstChildOfClass("Tool") and 1 or 0) or 0)
        
        if currentCount ~= lastCount then
            lastCount = currentCount
            RefreshButtons()
        end
    end
end)

NextBtn.MouseButton1Click:Connect(function() currentCatIndex = currentCatIndex % #Categories + 1 RefreshButtons() end)
PrevBtn.MouseButton1Click:Connect(function() currentCatIndex = (currentCatIndex - 2) % #Categories + 1 RefreshButtons() end)

-- === 6. KÉO THẢ VÀ INPUT ID (FIXED CHO MOBILE ĐA ĐIỂM) ===
local dragging, dragInput, dragStart, startPos

MinBtn.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and not dragging then
        dragging = true
        dragInput = input
        dragStart = input.Position
        startPos = MasterFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MasterFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input == dragInput then dragging = false dragInput = nil end
end)

