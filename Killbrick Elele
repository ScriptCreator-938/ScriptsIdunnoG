---------------------------------------------------------
-- Target Detection & Status Loop
---------------------------------------------------------
local function getKillbrick()
    local scpModel = workspace:FindFirstChild(TARGET_NAME)
    if scpModel then
        local kb = scpModel:FindFirstChild(KILLBRICK_NAME)
        if kb and kb:IsA("BasePart") then
            return kb
        end
    end
    return nil
end

task.spawn(function()
    while task.wait(0.5) do
        local kb = getKillbrick()
        if kb then
            StatusLabel.Text = "Status: Killbrick Mod Ready"
            StatusLabel.TextColor3 = Color3.fromRGB(0, 255, 120)
            if not originalSize then
                originalSize = kb.Size
            end
        else
            StatusLabel.Text = "Status: NOT A SCP"
            StatusLabel.TextColor3 = Color3.fromRGB(255, 70, 70)
            originalSize = nil
        end
    end
end)

---------------------------------------------------------
-- Mod Logic Updates
---------------------------------------------------------
-- Update Input Values
SizeBox.FocusLost:Connect(function()
    local coords = {}
    for num in string.gmatch(SizeBox.Text, "[%d%.%-]+") do
        table.insert(coords, tonumber(num))
    end
    if #coords >= 3 then
        targetSize = Vector3.new(coords[1], coords[2], coords[3])
    end
end)

RotateBox.FocusLost:Connect(function()
    local val = tonumber(RotateBox.Text)
    if val then
        rotateSpeed = val
    end
end)

-- Main Loop Logic
RunService.RenderStepped:Connect(function(dt)
    local kb = getKillbrick()
    if not kb then return end

    -- Handle Size Mod
    if sizeEnabled then
        kb.Size = targetSize
    elseif originalSize and kb.Size ~= originalSize and not sizeEnabled then
        kb.Size = originalSize
    end

    -- Handle Rotation Mod
    if rotateEnabled then
        local radPerSec = math.rad(90 * rotateSpeed)
        kb.CFrame = kb.CFrame * CFrame.Angles(0, radPerSec * dt, 0)
    end
end)

---------------------------------------------------------
-- Universal Dragging (Mobile & PC)
---------------------------------------------------------
local dragging = false
local dragInput, dragStart, startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    local newPos = UDim2.new(
        startPos.X.Scale,
        startPos.X.Offset + delta.X,
        startPos.Y.Scale,
        startPos.Y.Offset + delta.Y
    )
    TweenService:Create(MainFrame, TweenInfo.new(0.05, Enum.EasingStyle.Linear), {Position = newPos}):Play()
end

Header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

Header.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateDrag(input)
    end
end)

