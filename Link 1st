-- Hàm Teleport an toàn
local function SafeTP(pos)
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then
        char.HumanoidRootPart.CFrame = CFrame.new(pos)
    end
end

-- --- TAB MAIN ---
local MainTab = Window:CreateTab("Main", 4483362458)

-- 1. Auto Collect Drops (Updated with No Collision)
MainTab:CreateToggle({
   Name = "Auto Collect Drops",
   CurrentValue = false,
   Flag = "CollectFlag",
   Callback = function(Value)
      getgenv().AutoCollect = Value
      if Value then
         task.spawn(function()
            while getgenv().AutoCollect do
               local char = game.Players.LocalPlayer.Character
               if char and char:FindFirstChild("Head") then
                  local worlds = {"World1", "World2", "World3", "World4", "World5", "World6", "World7", "World8", "World9"}
                  for _, wName in pairs(worlds) do
                     local folder = workspace:FindFirstChild("Add") and workspace.Add:FindFirstChild(wName)
                     if folder then
                        for _, item in pairs(folder:GetChildren()) do
                           if item:IsA("BasePart") then
                              item.CanCollide = false -- Tắt va chạm để tránh văng nhân vật
                              item.CFrame = char.Head.CFrame
                           end
                        end
                     end
                  end
               end
               task.wait(0.5)
            end
         end)
      end
   end,
})

-- 2. Auto Get Crown (Tp)
MainTab:CreateToggle({
   Name = "Auto Get Crown (Tp)",
   CurrentValue = false,
   Flag = "CrownFlag",
   Callback = function(Value)
      getgenv().AutoCrown = Value
      if Value then
         task.spawn(function()
            while getgenv().AutoCrown do
               SafeTP(Vector3.new(-11, 5, -152))
               task.wait(0.5)
            end
         end)
      end
   end,
})

-- 3. Auto Combat
MainTab:CreateToggle({
   Name = "Auto Combat",
   CurrentValue = false,
   Flag = "CombatFlag",
   Callback = function(Value)
      getgenv().AutoCombat = Value
      if Value then
         task.spawn(function()
            while getgenv().AutoCombat do
               local char = game.Players.LocalPlayer.Character
               if char and char:FindFirstChild("Combat") then
                  local args = { game.Players.LocalPlayer } -- Tự động lấy chính bạn
                  char.Combat.RemoteUse:FireServer(unpack(args))
               end
               task.wait(0.1) -- Tốc độ đánh nhanh
            end
         end)
      end
   end,
})

