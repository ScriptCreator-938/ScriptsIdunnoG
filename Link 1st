-- Loop để giữ chỉ số không bị Reset khi Respawn
task.spawn(function()
    while true do
        local char = game.Players.LocalPlayer.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = getgenv().WS_Value
            hum.JumpPower = getgenv().JP_Value
        end
        task.wait(0.5)
    end
end)

