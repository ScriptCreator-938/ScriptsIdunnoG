local UI_UserName = createStatusLabel(Page6, "UserName")
local UI_DisplayName = createStatusLabel(Page6, "DisplayName")
local UI_UserID = createStatusLabel(Page6, "UserID")
local UI_Damage = createStatusLabel(Page6, "Damage")
local UI_IsSCP = createStatusLabel(Page6, "Is SCP")
local UI_Team = createStatusLabel(Page6, "Team")
local UI_Health = createStatusLabel(Page6, "Health")
local UI_Gun = createStatusLabel(Page6, "Gun")

task.spawn(function()
    while task.wait(0.1) do
        local target = getStatusTargetPlayer(getgenv().StatusTargetInput)
        if target then
            UI_UserName.Text = " UserName: " .. target.Name
            UI_DisplayName.Text = " DisplayName: " .. target.DisplayName
            UI_UserID.Text = " UserID: " .. tostring(target.UserId)
            
            local leaderboardStats = target:FindFirstChild("leaderstats")
            local dmgValue = leaderboardStats and (leaderboardStats:FindFirstChild("Damage") or leaderboardStats:FindFirstChild("Sát thương") or leaderboardStats:FindFirstChild("Kills"))
            UI_Damage.Text = " Damage: " .. (dmgValue and tostring(dmgValue.Value) or "0")
            
            local role = getPlayerRole(target)
            if role == "SCP" then
                UI_IsSCP.Text = " Is SCP: True"
                UI_IsSCP.TextColor3 = Color3.fromRGB(255, 60, 60)
            else
                UI_IsSCP.Text = " Is SCP: False"
                UI_IsSCP.TextColor3 = Color3.fromRGB(230, 230, 230)
            end
            
            if target.Team then
                UI_Team.Text = " Team: " .. target.Team.Name
                UI_Team.TextColor3 = target.TeamColor.Color
            else
                UI_Team.Text = " Team: Không có"
                UI_Team.TextColor3 = Color3.fromRGB(230, 230, 230)
            end
            
            if target.Character and target.Character:FindFirstChildOfClass("Humanoid") then
                local hum = target.Character:FindFirstChildOfClass("Humanoid")
                local hp = hum.Health
                local maxHp = hum.MaxHealth
                local pct = (maxHp > 0) and (hp / maxHp) or 0
                
                UI_Health.Text = string.format(" Health: %.1f / %.1f (%d%%)", hp, maxHp, math.floor(pct * 100))
                
                if pct >= 0.75 then
                    UI_Health.TextColor3 = Color3.fromRGB(50, 220, 50)
                elseif pct >= 0.50 then
                    UI_Health.TextColor3 = Color3.fromRGB(220, 220, 50)
                elseif pct >= 0.25 then
                    UI_Health.TextColor3 = Color3.fromRGB(220, 130, 30)
                else
                    UI_Health.TextColor3 = Color3.fromRGB(250, 50, 50)
                end
            else
                UI_Health.Text = " Health: DEAD / NOT SPAWNED"
                UI_Health.TextColor3 = Color3.fromRGB(150, 150, 150)
            end
            
            local currentWeapon = "None"
            if target.Character then
                local tool = target.Character:FindFirstChildOfClass("Tool")
                if tool then currentWeapon = tool.Name end
            end
            if currentWeapon == "None" and target:FindFirstChild("Backpack") then
                local tools = {}
                for _, t in ipairs(target.Backpack:GetChildren()) do
                    if t:IsA("Tool") then table.insert(tools, t.Name) end
                end
                if #tools > 0 then currentWeapon = table.concat(tools, ", ") end
            end
            UI_Gun.Text = " Gun: " .. currentWeapon
        else
            UI_UserName.Text = " UserName: ---"
            UI_DisplayName.Text = " DisplayName: ---"
            UI_UserID.Text = " UserID: ---"
            UI_Damage.Text = " Damage: ---"
            UI_IsSCP.Text = " Is SCP: ---"
            UI_Team.Text = " Team: ---"
            UI_Team.TextColor3 = Color3.fromRGB(230, 230, 230)
            UI_Health.Text = " Health: ---"
            UI_Health.TextColor3 = Color3.fromRGB(230, 230, 230)
            UI_Gun.Text = " Gun: ---"
        end
    end
end)

