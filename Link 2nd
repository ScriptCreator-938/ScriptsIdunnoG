-- UI Builders & Core Layout Generators
local function createToggle(parent, text, posY, globalVarName)
    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(0.9, 0, 0, 35)
    Btn.Position = UDim2.new(0.05, 0, 0, posY)
    Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    Btn.Text = text .. ": OFF"
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 11
    Btn.Parent = parent
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0, 6)

    if getgenv()[globalVarName] then
        Btn.Text = text .. ": ON"
        Btn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    end

    Btn.MouseButton1Click:Connect(function()
        getgenv()[globalVarName] = not getgenv()[globalVarName]
        Btn.Text = text .. (getgenv()[globalVarName] and ": ON" or ": OFF")
        Btn.BackgroundColor3 = getgenv()[globalVarName] and Color3.fromRGB(0, 150, 255) or Color3.fromRGB(45, 45, 45)
    end)
    return Btn
end

local function createTextBox(parent, labelText, placeholder, posY)
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0.9, 0, 0, 35)
    Frame.Position = UDim2.new(0.05, 0, 0, posY)
    Frame.BackgroundTransparency = 1
    Frame.Parent = parent

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.5, 0, 1, 0)
    Label.Text = labelText
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.Font = Enum.Font.GothamSemibold
    Label.TextSize = 11
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.BackgroundTransparency = 1
    Label.Parent = Frame

    local Box = Instance.new("TextBox")
    Box.Size = UDim2.new(0.48, 0, 1, 0)
    Box.Position = UDim2.new(0.52, 0, 0, 0)
    Box.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Box.TextColor3 = Color3.fromRGB(255, 255, 255)
    Box.PlaceholderText = placeholder
    Box.Text = ""
    Box.Font = Enum.Font.Gotham
    Box.TextSize = 11
    Box.Parent = Frame
    Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 6)

    -- Fade and Glow Input Effect on Enter (FocusLost)
    Box.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local currentBg = Box.BackgroundColor3
            Box.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
            Box.BackgroundTransparency = 0.2
            
            local fadeTween = TweenService:Create(Box, TweenInfo.new(0.8, Enum.EasingStyle.Linear), {
                BackgroundColor3 = currentBg,
                BackgroundTransparency = 0
            })
            fadeTween:Play()
        end
    end)

    return Box
end

