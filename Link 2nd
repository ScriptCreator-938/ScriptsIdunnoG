    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.5, 0, 1, 0)
    Label.Text = labelText
    Label.TextColor3 = Color3.fromRGB(200, 200, 200)
    Label.Font = Enum.Font.GothamSemibold
    Label.TextSize = 11
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.BackgroundTransparency = 1
    Label.Parent = Frame

    local Box = Instance.new("TextBox")
    Box.Size = UDim2.new(0.48, 0, 1, 0)
    Box.Position = UDim2.new(0.52, 0, 0, 0)
    Box.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Box.TextColor3 = Color3.fromRGB(255, 255, 255)
    Box.PlaceholderText = placeholder
    Box.Text = ""
    Box.Font = Enum.Font.Gotham
    Box.TextSize = 11
    Box.Parent = Frame
    Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 6)

    Box.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            local currentBg = Box.BackgroundColor3
            Box.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
            Box.BackgroundTransparency = 0.2
            local fadeTween = TweenService:Create(Box, TweenInfo.new(0.8, Enum.EasingStyle.Linear), {
                BackgroundColor3 = currentBg,
                BackgroundTransparency = 0
            })
            fadeTween:Play()
        end
    end)
    return Box
end

