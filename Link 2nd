local function getStatusTargetPlayer(str)
    if str == "" then return nil end
    str = string.lower(str)
    for _, player in ipairs(Players:GetPlayers()) do
        if string.sub(string.lower(player.Name), 1, #str) == str or string.sub(string.lower(player.DisplayName), 1, #str) == str then
            return player
        end
    end
    return nil
end

