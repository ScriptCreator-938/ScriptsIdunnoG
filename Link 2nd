if not getgenv()._origFire then
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    getgenv()._origFire = mt.__namecall
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if getgenv().rapidFireEnabled and (method == "FireServer" or method == "InvokeServer") then
            if getgenv().DetectedRemote and self == getgenv().DetectedRemote then
                for i = 1, (getgenv().rapidFire - 1) do 
                    getgenv()._origFire(self, unpack(args)) 
                end
                return getgenv()._origFire(self, ...)
            end
            
            if args[1] and type(args[1]) == "string" then
                local argLower = string.lower(args[1])
                if argLower == "shoot" or argLower == "fire" or argLower == "bullet" or string.find(argLower, "hit") then
                    getgenv().DetectedRemote = self
                    
                    task.spawn(function()
                        updateStatusUI("LOCKED: " .. string.upper(tostring(self.Name)), true)
                    end)
                    
                    for i = 1, (getgenv().rapidFire - 1) do 
                        getgenv()._origFire(self, unpack(args)) 
                    end
                end
            end
        end
        return getgenv()._origFire(self, ...)
    end)
    setreadonly(mt, true)
end

-- Game Team & Faction Logic
local function getPlayerRole(player)
    if not player or not player.Character then return "Unknown" end
    if player.Team then
        local teamName = string.lower(player.Team.Name)
        if string.find(teamName, "scp") then return "SCP" end
        if string.find(teamName, "guard") or string.find(teamName, "bao ve") then return "Guard" end
        if string.find(teamName, "mtf") or string.find(teamName, "co dong") then return "MTF" end
    end
    return "Unknown"
end

local function isEnemy(targetPlayer)
    if not getgenv().TeamCheck then return true end
    local myRole = getPlayerRole(LocalPlayer)
    local targetRole = getPlayerRole(targetPlayer)
    if myRole == "Guard" and targetRole == "SCP" then return true end
    if myRole == "SCP" and (targetRole == "Guard" or targetRole == "MTF") then return true end
    if myRole == "MTF" and targetRole == "SCP" then return true end
    return false
end

local function isVisible(targetPart)
    if not getgenv().WallCheck then return true end
    local castPoints = {Camera.CFrame.Position, targetPart.Position}
    local ignoreList = {LocalPlayer.Character, targetPart.Parent}
    local parts = Camera:GetPartsObscuringTarget(castPoints, ignoreList)
    return #parts == 0
end

