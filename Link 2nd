TeamCycleBtn.MouseButton1Click:Connect(function()
    currentModeIndex = currentModeIndex == #TeamModes and 1 or currentModeIndex + 1
    getgenv().HitboxTargetTeam = TeamModes[currentModeIndex]
    TeamCycleBtn.Text = "TARGET TEAM: " .. string.upper(getgenv().HitboxTargetTeam)
end)

