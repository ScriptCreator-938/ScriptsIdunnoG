-- Xoá bản cũ
if game:GetService("CoreGui"):FindFirstChild("Valley_Independent_V10") then
    game:GetService("CoreGui"):FindFirstChild("Valley_Independent_V10"):Destroy()
end

local player = game:GetService("Players").LocalPlayer
local coreGui = game:GetService("CoreGui")
local inputService = game:GetService("UserInputService")

-- 1. KHỞI TẠO GUI
local screenGui = Instance.new("ScreenGui", coreGui)
screenGui.Name = "Valley_Independent_V10"
screenGui.ResetOnSpawn = false

local mainFrame = Instance.new("Frame", screenGui)
mainFrame.Name = "MainFrame"
mainFrame.Size = UDim2.new(0, 180, 0, 130)
mainFrame.Position = UDim2.new(0.7, 0, 0.3, 0)
mainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
mainFrame.Active = true

local corner = Instance.new("UICorner", mainFrame)
local stroke = Instance.new("UIStroke", mainFrame)
stroke.Color = Color3.fromRGB(255, 255, 255)
stroke.Thickness = 1.5

local function createBtn(text, pos, size, color)
    local btn = Instance.new("TextButton", mainFrame)
    btn.Text = text
    btn.Position = pos
    btn.Size = size
    btn.BackgroundColor3 = color
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 10
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    return btn
end

-- Khởi tạo nút
local dropBtn = createBtn("DROP (Z)", UDim2.new(0, 5, 0, 5), UDim2.new(0.7, -5, 0, 35), Color3.fromRGB(150, 0, 0))
local minBtn = createBtn("-", UDim2.new(0.7, 5, 0, 5), UDim2.new(0.3, -10, 0, 35), Color3.fromRGB(50, 50, 50))
local modeBtn = createBtn("FIREMODE (V)", UDim2.new(0, 5, 0, 45), UDim2.new(0.5, -7, 0, 35), Color3.fromRGB(30, 90, 30))
local safeBtn = createBtn("SAFETY (H)", UDim2.new(0.5, 3, 0, 45), UDim2.new(0.5, -8, 0, 35), Color3.fromRGB(90, 90, 30))
local laserBtn = createBtn("LASER (G)", UDim2.new(0, 5, 0, 85), UDim2.new(0.5, -7, 0, 35), Color3.fromRGB(100, 20, 100))
local lightBtn = createBtn("LIGHT (F)", UDim2.new(0.5, 3, 0, 85), UDim2.new(0.5, -8, 0, 35), Color3.fromRGB(20, 100, 100))

-- 2. LOGIC GỬI LỆNH SÚNG
local function sendKey(key)
    local tool = player.Character and player.Character:FindFirstChildOfClass("Tool")
    if tool and tool:FindFirstChild("Remotes") and tool.Remotes:FindFirstChild("Activation") then
        tool.Remotes.Activation:FireServer({["M"] = "KD", ["K"] = key})
    end
end

laserBtn.MouseButton1Click:Connect(function() sendKey("G") end)
lightBtn.MouseButton1Click:Connect(function() sendKey("F") end)
modeBtn.MouseButton1Click:Connect(function() sendKey("V") end)
safeBtn.MouseButton1Click:Connect(function() sendKey("H") end)
dropBtn.MouseButton1Click:Connect(function()
    local tool = player.Character and player.Character:FindFirstChildOfClass("Tool")
    if tool and tool:FindFirstChild("DropServer") then
        tool.DropServer.KeySend:FireServer()
    end
end)

-- 3. HỆ THỐNG KÉO THẢ 1 NGÓN ĐỘC LẬP (ANTI MULTI-TOUCH)
local currentTrackedInput = nil -- Biến lưu trữ ngón tay ĐẦU TIÊN được phép kéo
local dragStart, startPos

local function startDrag(input)
    -- Nếu chưa có ngón tay nào thâu tóm quyền điều khiển, thì nhận ngón tay này
    if currentTrackedInput == nil then
        currentTrackedInput = input
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end

-- Bắt đầu chạm vào Khung Nền
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        startDrag(input)
    end
end)

-- Bắt đầu chạm vào nút Minimize
minBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        startDrag(input)
    end
end)

-- Theo dõi di chuyển của CHỈ ngón tay đã đăng ký
inputService.InputChanged:Connect(function(input)
    if input == currentTrackedInput then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Khi ngón tay điều khiển nhấc lên, giải phóng để ngón khác có thể dùng sau đó
inputService.InputEnded:Connect(function(input)
    if input == currentTrackedInput then
        currentTrackedInput = nil
    end
end)

-- 4. LOGIC THU NHỎ / PHÓNG TO
local minimized = false
minBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    local buttons = {dropBtn, modeBtn, safeBtn, laserBtn, lightBtn}
    
    if minimized then
        for _, btn in pairs(buttons) do btn.Visible = false end
        mainFrame:TweenSize(UDim2.new(0, 45, 0, 45), "Out", "Quart", 0.25, true)
        minBtn.Position = UDim2.new(0, 0, 0, 0)
        minBtn.Size = UDim2.new(1, 0, 1, 0)
        minBtn.Text = "+"
    else
        mainFrame:TweenSize(UDim2.new(0, 180, 0, 130), "Out", "Quart", 0.25, true)
        task.wait(0.05)
        minBtn.Position = UDim2.new(0.7, 5, 0, 5)
        minBtn.Size = UDim2.new(0.3, -10, 0, 35)
        minBtn.Text = "-"
        task.wait(0.15)
        for _, btn in pairs(buttons) do btn.Visible = true end
    end
end)
