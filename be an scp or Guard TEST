local function getNearestDoorOrGate()
	if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return nil end
	local charPos = LocalPlayer.Character.HumanoidRootPart.Position
	local nearestObj = nil
	local minDistance = math.huge

	local foldersToScan = {}
	if DoorsFolder then table.insert(foldersToScan, DoorsFolder) end
	if GatesFolder then table.insert(foldersToScan, GatesFolder) end

	for _, folder in ipairs(foldersToScan) do
		for _, obj in ipairs(folder:GetChildren()) do
			for _, descendant in ipairs(obj:GetDescendants()) do
				if descendant:IsA("ClickDetector") then
					local parentPart = descendant.Parent
					if parentPart and parentPart:IsA("BasePart") then
						local dist = (parentPart.Position - charPos).Magnitude
						if dist < minDistance then
