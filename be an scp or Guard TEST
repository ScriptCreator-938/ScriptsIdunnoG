-- Hàm lấy ID thực tế của Cửa/Gate dựa trên các thuộc tính cấu trúc ẩn của game
local function getActualDoorId(obj)
	if not obj then return "Unknown" end
	local idValue = obj:FindFirstChild("ID") or obj:FindFirstChild("DoorID") or obj:FindFirstChild("GateID")
	if idValue and (idValue:IsA("StringValue") or idValue:IsA("IntValue") or idValue:IsA("NumberValue")) then
		return tostring(idValue.Value)
	end
	local config = obj:FindFirstChild("Configuration") or obj:FindFirstChild("Settings")
	if config then
		local altId = config:FindFirstChild("ID") or config:FindFirstChild("DoorID")
		if altId then return tostring(altId.Value) end
	end
	return obj.Name
end

