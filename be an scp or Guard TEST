local function getSmartTargetPlayer(str)
	if str == "" then return nil end
	str = string.lower(str)
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and (string.sub(string.lower(player.Name), 1, #str) == str or string.sub(string.lower(player.DisplayName), 1, #str) == str) then
			return player
		end
	end
	return nil
end

