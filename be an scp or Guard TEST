        if target then
            UI_UserName.Text = " Username: " .. target.Name
            UI_DisplayName.Text = " DisplayName: " .. target.DisplayName
            UI_UserID.Text = " UserId: " .. tostring(target.UserId)

            local leaderboardStats = target:FindFirstChild("leaderstats")
            local dmgValueObj = leaderboardStats and (leaderboardStats:FindFirstChild("Damage") or leaderboardStats:FindFirstChild("Sát thương") or leaderboardStats:FindFirstChild("Kills"))
            local rawDmg = dmgValueObj and dmgValueObj.Value or 0
            UI_Damage.Text = " Damage: " .. formatNumberWithDots(rawDmg)

            local role = getPlayerRole(target)
            local detectedScpStr = "None"
            
            if role == "SCP" then
                UI_IsSCP.Text = " IsScp: True"
                UI_IsSCP.TextColor3 = Color3.fromRGB(255, 60, 60)
                
                if target.Character then
                    local scpMatch = string.match(target.Character.Name, "^SCP%-[0-9a-zA-Z%-]+")
                    detectedScpStr = scpMatch or target.Character.Name
                    UI_SCPName.Text = " SCP: " .. detectedScpStr
                else
                    UI_SCPName.Text = " SCP: Không rõ Model"
                end

                local scpKillFound = "0"
                local myPlayerGui = LocalPlayer:FindFirstChild("PlayerGui")
                
                if myPlayerGui and detectedScpStr ~= "None" then
                    local mainFrame = myPlayerGui:FindFirstChild("Main") and myPlayerGui.Main:FindFirstChild("Frame")
                    local scpList = mainFrame and mainFrame:FindFirstChild("ScpList")
                    local targetScpNode = scpList and scpList:FindFirstChild(detectedScpStr)
                    
                    if targetScpNode and targetScpNode:FindFirstChild("Kills") and targetScpNode.Kills:IsA("TextLabel") then
                        local cleanNum = string.match(targetScpNode.Kills.Text, "%d+")
                        scpKillFound = cleanNum or "0"
                    end
                end

                UI_SCPKills.Text = " SCP Kill: " .. scpKillFound
            else
                UI_IsSCP.Text = " IsScp: False"
                UI_IsSCP.TextColor3 = Color3.fromRGB(230, 230, 230)
                UI_SCPName.Text = " SCP: None"
                UI_SCPKills.Text = " SCP Kill: None"
            end

            if target.Team then
                UI_Team.Text = " Team: " .. target.Team.Name
                UI_Team.TextColor3 = target.TeamColor.Color
            else
                UI_Team.Text = " Team: Không có"
                UI_Team.TextColor3 = Color3.fromRGB(230, 230, 230)
            end

            if target.Character and target.Character:FindFirstChildOfClass("Humanoid") then
                local hum = target.Character:FindFirstChildOfClass("Humanoid")
                local hp = hum.Health
                local maxHp = hum.MaxHealth
                local pct = (maxHp > 0) and (hp / maxHp) or 0

                UI_Health.Text = string.format(" Health: %.1f / %.1f (%d%%)", hp, maxHp, math.floor(pct * 100))
                if pct >= 0.75 then UI_Health.TextColor3 = Color3.fromRGB(50, 220, 50)
                elseif pct >= 0.50 then UI_Health.TextColor3 = Color3.fromRGB(220, 220, 50)
                elseif pct >= 0.25 then UI_Health.TextColor3 = Color3.fromRGB(220, 130, 30)
                else UI_Health.TextColor3 = Color3.fromRGB(250, 50, 50) end
            else
                UI_Health.Text = " Health: DEAD / NOT SPAWNED"
                UI_Health.TextColor3 = Color3.fromRGB(150, 150, 150)
            end

            local currentWeapon = "None"
            if target.Character then
                local tool = target.Character:FindFirstChildOfClass("Tool")
                if tool then currentWeapon = tool.Name end
            end
            UI_Gun.Text = " Gun: " .. currentWeapon
        else
            UI_UserName.Text = " Username: ---"
            UI_DisplayName.Text = " DisplayName: ---"
            UI_UserID.Text = " UserId: ---"
            UI_Damage.Text = " Damage: ---"
