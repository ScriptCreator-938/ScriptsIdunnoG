                    end)

                    for i = 1, (getgenv().rapidFire - 1) do 
                        getgenv()._origFire(self, unpack(args)) 
                    end
                end
            end
        end
        return getgenv()._origFire(self, ...)
    end)
    setreadonly(mt, true)
end

-- Helper: Get Player Target by Smart Username Match
local function getSmartTargetPlayer(str)
    if str == "" then return nil end
    str = string.lower(str)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and (string.sub(string.lower(player.Name), 1, #str) == str or string.sub(string.lower(player.DisplayName), 1, #str) == str) then
            return player
        end
    end
    return nil
end

-- Helper: Get SCP Model by Number String
local function getSCPModelByNumber(numStr)
    if numStr == "" then return nil end
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj:IsA("Model") then
            if string.match(obj.Name, "^SCP%-" .. numStr) then
                return obj
            end
        end
    end
    return nil
end

