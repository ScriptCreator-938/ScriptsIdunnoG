		if (getgenv().AimbotEnabled or getgenv().SilentAimEnabled) and not IsSwipeBreaking then
			local targetCenter = getDynamicFOVCenter()
			local validEnemies = {}
			local allPlayers = Players:GetPlayers()

			for i = 1, #allPlayers do
				local player = allPlayers[i]
				if player ~= LocalPlayer and player.Character and player.Character:FindFirstChildOfClass("Humanoid") and player.Character:FindFirstChildOfClass("Humanoid").Health > 0 then
					if isEnemy(player) then
						local rootPart = player.Character:FindFirstChild("HumanoidRootPart") or player.Character:FindFirstChild("Head")
						if rootPart then
							local screenPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
							if onScreen then
								local distanceToCenter = (Vector2.new(screenPos.X, screenPos.Y) - targetCenter).Magnitude
								if distanceToCenter < getgenv().AimbotFOV then
									table.insert(validEnemies, {
										Player = player,
										Dist = distanceToCenter,
										WorldDist = (rootPart.Position - Camera.CFrame.Position).Magnitude,
										ScreenPos = Vector2.new(screenPos.X, screenPos.Y)
									})
								end
							end
						end
					end
				end
			end

			table.sort(validEnemies, function(a, b) return a.Dist < b.Dist end)

			local finalAimbotPart = nil
			local maxChecks = math.clamp(#validEnemies, 1, 3)
			for i = 1, maxChecks do
				local targetEnemy = validEnemies[i]
				if targetEnemy then
					local targetPart = getAimbotTargetPart(targetEnemy.Player.Character)
					if targetPart then finalAimbotPart = targetPart; break end
				end
			end
			CurrentClosestPart = finalAimbotPart

			if #validEnemies > 0 and getgenv().SilentAimEnabled then
				local mode = getgenv().SilentAimTargetMode
				if mode == "Nearest" then
					table.sort(validEnemies, function(a, b) return a.Dist < b.Dist end)
				elseif mode == "Farthest" then
					table.sort(validEnemies, function(a, b) return a.Dist > b.Dist end)
				elseif mode == "Random" then
					local randIndex = math.random(1, #validEnemies)
					validEnemies[1], validEnemies[randIndex] = validEnemies[randIndex], validEnemies[1]
				end

				local finalSilentPart = nil
				for i = 1, #validEnemies do
					local targetEnemy = validEnemies[i]
					local targetPart = getAimbotTargetPart(targetEnemy.Player.Character)
					if targetPart then finalSilentPart = targetPart; break end
				end
				CurrentSilentAimPart = finalSilentPart
			else
				CurrentSilentAimPart = nil
			end
		else
			CurrentClosestPart = nil
			CurrentSilentAimPart = nil
		end
		task.wait(0.035)
	end
end)

-- Aimbot Core & FOV Visual Rendering
RunService.RenderStepped:Connect(function()
	local targetCenter = getDynamicFOVCenter()
	FOVCircle.Radius = getgenv().AimbotFOV
	FOVCircle.Position = targetCenter
	FOVCircle.Visible = getgenv().ShowFOV and (getgenv().AimbotEnabled or getgenv().SilentAimEnabled)

	if getgenv().SilentAimEnabled and CurrentSilentAimPart and not IsSwipeBreaking then
		FOVCircle.Color = Color3.fromRGB(0, 255, 0)
		local screenPos, _ = Camera:WorldToViewportPoint(CurrentSilentAimPart.Position)
		TracerLine.From = targetCenter
		TracerLine.To = Vector2.new(screenPos.X, screenPos.Y)
		TracerLine.Visible = true

		if getgenv().SilentAimBoxDetect and CurrentSilentAimPart.Parent and CurrentSilentAimPart.Parent:FindFirstChild("HumanoidRootPart") then
			local targetChar = CurrentSilentAimPart.Parent
			local hrp = targetChar.HumanoidRootPart
			local _, onScreen = Camera:WorldToViewportPoint(hrp.Position)
			if onScreen then
				local extentsSize = targetChar:GetExtentsSize()
				local topWorld = (hrp.CFrame * CFrame.new(0, extentsSize.Y / 2, 0)).Position
				local bottomWorld = (hrp.CFrame * CFrame.new(0, -extentsSize.Y / 2, 0)).Position
				local topScreen = Camera:WorldToViewportPoint(topWorld)
				local bottomScreen = Camera:WorldToViewportPoint(bottomWorld)
				local boxHeight = math.abs(topScreen.Y - bottomScreen.Y)
				local boxWidth = boxHeight * 0.65
				TargetBox.Size = Vector2.new(boxWidth, boxHeight)
				TargetBox.Position = Vector2.new(topScreen.X - (boxWidth / 2), topScreen.Y)
				TargetBox.Visible = true
			else
				TargetBox.Visible = false
			end
		else
			TargetBox.Visible = false
		end
	else
		FOVCircle.Color = Color3.fromRGB(255, 0, 127)
		TracerLine.Visible = false
		TargetBox.Visible = false
	end

	if getgenv().AimbotEnabled and CurrentClosestPart and not IsSwipeBreaking then
		Camera.CFrame = CFrame.new(Camera.CFrame.Position, CurrentClosestPart.Position)
	end
end)

-- Hitbox Expander Task Loop
task.spawn(function()
	while task.wait(0.5) do
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
				local hrp = player.Character.HumanoidRootPart
				local role = getPlayerRole(player)
				if not OriginalHitboxes[player.Name] then OriginalHitboxes[player.Name] = hrp.Size end

				local shouldExpand = false
				if getgenv().HitboxTargetTeam == "All" then shouldExpand = true
				elseif getgenv().HitboxTargetTeam == "SCP" and role == "SCP" then shouldExpand = true
				elseif getgenv().HitboxTargetTeam == "Guard" and role == "Guard" then shouldExpand = true
				elseif getgenv().HitboxTargetTeam == "MTF" and role == "MTF" then shouldExpand = true end

				if getgenv().HitboxEnabled and shouldExpand then
					hrp.Size = Vector3.new(getgenv().HitboxSize, getgenv().HitboxSize, getgenv().HitboxSize)
					hrp.Transparency = 0.7
					hrp.Color = Color3.fromRGB(255, 0, 0)
					hrp.CanCollide = false
				else
					hrp.Size = OriginalHitboxes[player.Name] or Vector3.new(2, 2, 2)
					hrp.Transparency = 1
					hrp.CanCollide = true
				end
			end
		end
	end
end)

