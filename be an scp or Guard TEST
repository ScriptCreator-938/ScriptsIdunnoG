local function formatNumberWithDots(amount)
	local formatted = tostring(amount)
	while true do
		formatted, k = string.gsub(formatted, "^(-?%d+)(%d%d%d)", '%1.%2')
		if k == 0 then break end
	end
	return formatted
end

local function getPlayerRole(player)
	if not player or not player.Character then return "Unknown" end
	if player.Team then
		local teamName = string.lower(player.Team.Name)
		if string.find(teamName, "scp") then return "SCP" end
		if string.find(teamName, "guard") or string.find(teamName, "bao ve") then return "Guard" end
		if string.find(teamName, "mtf") or string.find(teamName, "co dong") then return "MTF" end
	end
	return "Unknown"
end

local function isEnemy(targetPlayer)
	if not getgenv().TeamCheck then return true end
	local myRole = getPlayerRole(LocalPlayer)
	local targetRole = getPlayerRole(targetPlayer)
	if myRole == "Guard" and targetRole == "SCP" then return true end
	if myRole == "SCP" and (targetRole == "Guard" or targetRole == "MTF") then return true end
	if myRole == "MTF" and targetRole == "SCP" then return true end
	return false
end

local function isPartVisible(targetPart)
	local castPoints = {Camera.CFrame.Position, targetPart.Position}
	local ignoreList = {LocalPlayer.Character, targetPart.Parent}
	local parts = Camera:GetPartsObscuringTarget(castPoints, ignoreList)
	return #parts == 0
end

local function getAimbotTargetPart(character)
	if not getgenv().WallCheck and not getgenv().WallCheckV2 then
		return character:FindFirstChild("Head")
	end
	if getgenv().WallCheck and not getgenv().WallCheckV2 then
		local head = character:FindFirstChild("Head")
		if head and isPartVisible(head) then return head end
		return nil
	end
	if getgenv().WallCheckV2 then
		local head = character:FindFirstChild("Head")
		if head and isPartVisible(head) then return head end
		local torso = character:FindFirstChild("Torso")
		if torso and isPartVisible(torso) then return torso end
		local limbs = {"Right Arm", "Left Arm", "Right Leg", "Left Leg"}
		for i = 1, #limbs do
			local limb = character:FindFirstChild(limbs[i])
			if limb and isPartVisible(limb) then return limb end
		end
	end
	return nil
end

